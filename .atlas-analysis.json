{
  "projectType": "sdk-library",
  "projectName": "libpg_query",
  "projectDescription": "A C library that exposes the PostgreSQL parser outside of the server, enabling SQL parsing, scanning, normalization, fingerprinting, and deparsing in any application.",
  "theme": "luma",
