  "keyFeatures": [
    "SQL query parsing using the actual PostgreSQL parser",
    "Token scanning/lexing for syntax highlighting",
    "Query normalization (replace literals with $1, $2, ...)",
    "Query fingerprinting for identifying structurally similar queries",
    "Deparsing (convert parse tree back to SQL text with pretty printing)",
    "PL/pgSQL function parsing",
    "Statement splitting for multi-statement inputs",
    "Protobuf serialization of parse trees",
    "Fast utility statement detection without full parse",
    "Query summary extraction without full Protobuf serialization"
  ],
